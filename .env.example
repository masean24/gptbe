# ==================== BOT ====================
BOT_TOKEN=your_telegram_bot_token_here
ADMIN_IDS=123456789,987654321

# Channel/Group ID untuk notifikasi (invite berhasil, redeem, pembayaran)
# Contoh: -1001234567890
LOG_CHAT_ID=-1001234567890

# ==================== DATABASE ====================
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/gptibot

# ==================== SERVER ====================
PORT=3000
JWT_SECRET=your_super_secret_jwt_key_change_this

# ==================== QRIS PAYMENT ====================
QRIS_API_URL=https://qris.hubify.store/api
QRIS_API_KEY=sk_xxxxxxxxxx
QRIS_WEBHOOK_SECRET=your_webhook_secret

# ==================== PRICING ====================
# Credit harga dalam Rupiah (1 kredit = 1 invite)
CREDIT_PRICE=5000

# ==================== CHATGPT ====================
MAX_INVITES_PER_ACCOUNT=4

# ==================== WEB FRONTEND ====================
FRONTEND_URL=https://your-app.vercel.app

# ==================== SMTP (Nodemailer) ====================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youremail@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM=GPT Invite Bot <youremail@gmail.com>

# ==================== TELEGRAM TOPICS ====================
# message_thread_id for forum group topic (optional, leave empty for general)
LOG_TOPIC_ID=

# ==================== FORCE JOIN ====================
# Bot must be admin in both channel and group
REQUIRED_CHANNEL_ID=@yourchannel
REQUIRED_GROUP_ID=-1001234567890

# ==================== ADMIN WEB LOGIN ====================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_strong_admin_password_here
